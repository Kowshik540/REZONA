# ═══════════════════════════════════════════════════════════════════════════════
# REZONA — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/rezona?retryWrites=true&w=majority

# ─── JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ──
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_STRING

# ─── CORS (comma-separated production domains) ────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── AI APIs ──────────────────────────────────────────────────────────────────
XAI_API_KEY=your_groq_api_key_here

# ─── Job Search APIs ──────────────────────────────────────────────────────────
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
JSEARCH_API_KEY=your_rapidapi_key

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
